<Window x:Class="SilentStream.App.ControlUI.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding VersionText, StringFormat='SilentStream 제어판 — {0}'}"
        Width="880" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        ShowInTaskbar="False">
    <!-- Ctrl+Shift+F12로 토글되는 다크 테마 제어 UI (계획서 §3.8) -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
        <!-- 실시간 레벨 미터: 값(0~1)을 막대로, 색은 ViewModel이 dB에 따라 지정 -->
        <Style x:Key="Meter" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Background" Value="#15151A" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,3" />
        </Style>
        <Style x:Key="DimLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DimBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 상단: 상태 배지 + 시작/중지 + 성능 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Border DockPanel.Dock="Left" CornerRadius="4" Padding="12,6"
                    Background="{Binding StateColor}">
                <TextBlock Text="{Binding StateBadge}" FontWeight="Bold" FontSize="16"
                           Foreground="White" />
            </Border>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="시작" Command="{Binding StartCommand}" Width="84" Margin="6,0" />
                <Button Content="중지" Command="{Binding StopCommand}" Width="84" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding BitrateText}" Style="{StaticResource MetricText}" />
                <TextBlock Text="{Binding FpsText}" Style="{StaticResource MetricText}" />
                <TextBlock Text="{Binding CpuText, StringFormat=CPU {0}}" Style="{StaticResource MetricText}" />
                <TextBlock Text="{Binding GpuText, StringFormat=GPU {0}}" Style="{StaticResource MetricText}" />
            </StackPanel>
        </DockPanel>

        <!-- 마이크 무음 경고 배너 -->
        <Border Grid.Row="1" Margin="0,0,0,10" CornerRadius="4" Padding="10,7"
                Background="#5A2020" BorderBrush="#E74C3C" BorderThickness="1"
                Visibility="{Binding MicWarningVisible, Converter={StaticResource B2V}}">
            <TextBlock Text="{Binding MicWarningText}" Foreground="White" TextWrapping="Wrap" />
        </Border>

        <!-- 본문: 좌(믹서+로그) / 우(캡처·자원·녹화·설정) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- 왼쪽 열 -->
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="오디오 믹서" Margin="0,0,0,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="6">
                            <!-- 소스 카드 목록 (시스템 + 마이크 N개) -->
                            <ItemsControl ItemsSource="{Binding AudioSources}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#22222A" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                            <StackPanel>
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right" Content="✕" Width="24" Padding="0"
                                                            Background="#5A2020"
                                                            Command="{Binding RemoveCommand}"
                                                            ToolTip="이 소스 제거"
                                                            Visibility="{Binding CanRemove, Converter={StaticResource B2V}}" />
                                                    <CheckBox DockPanel.Dock="Right" Content="음소거" Margin="0,0,8,0"
                                                              IsChecked="{Binding Muted, Mode=TwoWay}" />
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                </DockPanel>

                                                <!-- 마이크 장치 선택 -->
                                                <ComboBox Margin="0,6,0,0"
                                                          ItemsSource="{Binding AvailableDevices}"
                                                          SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                                                          DisplayMemberPath="Name"
                                                          Visibility="{Binding IsMic, Converter={StaticResource B2V}}" />

                                                <!-- 실시간 레벨 미터 -->
                                                <ProgressBar Style="{StaticResource Meter}"
                                                             Value="{Binding MeterRms, Mode=OneWay}"
                                                             Foreground="{Binding MeterBrush}" />

                                                <!-- 증폭(게인) -->
                                                <DockPanel Margin="0,4,0,0">
                                                    <TextBlock DockPanel.Dock="Left" Text="증폭" Width="34"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding GainDbText}"
                                                               Width="64" TextAlignment="Right"
                                                               VerticalAlignment="Center" FontFamily="Consolas" />
                                                    <Slider Minimum="0" Maximum="4" Value="{Binding Gain, Mode=TwoWay}"
                                                            TickFrequency="0.05" IsSnapToTickEnabled="True"
                                                            ToolTip="0=무음, 1=원음, 1 초과는 증폭(최대 약 +12dB)" />
                                                </DockPanel>

                                                <!-- 노이즈 게이트 -->
                                                <DockPanel Margin="0,2,0,0">
                                                    <CheckBox DockPanel.Dock="Left" Content="게이트" Width="64"
                                                              IsChecked="{Binding GateEnabled, Mode=TwoWay}"
                                                              VerticalAlignment="Center"
                                                              ToolTip="조용할 때 잡음을 차단합니다." />
                                                    <TextBlock DockPanel.Dock="Right" Width="64" TextAlignment="Right"
                                                               VerticalAlignment="Center" FontFamily="Consolas"
                                                               Foreground="{StaticResource DimBrush}"
                                                               Text="{Binding GateThresholdDb, StringFormat={}{0:0} dB}" />
                                                    <Slider Minimum="-80" Maximum="0"
                                                            Value="{Binding GateThresholdDb, Mode=TwoWay}"
                                                            IsEnabled="{Binding GateEnabled}"
                                                            TickFrequency="1" IsSnapToTickEnabled="True" />
                                                </DockPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <DockPanel Margin="0,2,0,0">
                                <Button DockPanel.Dock="Left" Content="+ 마이크 추가" Width="120"
                                        Command="{Binding AddMicCommand}" />
                                <Button DockPanel.Dock="Right" Content="↺ 장치 새로고침" Width="120"
                                        Background="#333A46" Command="{Binding RefreshDevicesCommand}" />
                                <TextBlock />
                            </DockPanel>

                            <Separator Margin="0,10,0,8" />

                            <!-- 마스터 -->
                            <TextBlock Text="마스터 출력" FontWeight="Bold" />
                            <ProgressBar Style="{StaticResource Meter}"
                                         Value="{Binding MasterMeterRms, Mode=OneWay}"
                                         Foreground="{Binding MasterMeterBrush}" />
                            <TextBlock Style="{StaticResource DimLabel}"
                                       Text="아래 필터는 다음 세션부터 적용됩니다." Margin="0,2,0,4" />
                            <CheckBox Content="노이즈 억제 (afftdn)" IsChecked="{Binding NoiseSuppressionEnabled, Mode=TwoWay}" />
                            <Slider Minimum="1" Maximum="40" Value="{Binding NoiseSuppressionDb, Mode=TwoWay}"
                                    IsEnabled="{Binding NoiseSuppressionEnabled}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ToolTip="잡음 감소량(dB). 높을수록 강하게 억제." />
                            <CheckBox Content="컴프레서 (음량 평준화)" Margin="0,6,0,0"
                                      IsChecked="{Binding CompressorEnabled, Mode=TwoWay}" />
                            <CheckBox Content="리미터 (클리핑 방지)" Margin="0,4,0,0"
                                      IsChecked="{Binding LimiterEnabled, Mode=TwoWay}" />
                            <DockPanel Margin="0,6,0,0">
                                <TextBlock DockPanel.Dock="Left" Text="마스터 게인" Width="74"
                                           VerticalAlignment="Center" />
                                <TextBlock DockPanel.Dock="Right" Text="{Binding MasterGainText}" Width="64"
                                           TextAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" />
                                <Slider Minimum="-12" Maximum="12" Value="{Binding MasterGainDb, Mode=TwoWay}"
                                        TickFrequency="0.5" IsSnapToTickEnabled="True" />
                            </DockPanel>
                        </StackPanel>
                    </ScrollViewer>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="로그 (최근 1000줄)">
                    <ListBox x:Name="LogList" ItemsSource="{Binding LogLines}"
                             FontFamily="Consolas" FontSize="11"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True" />
                </GroupBox>
            </Grid>

            <!-- 오른쪽 열 -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox Header="송출 미리보기">
                        <Border Background="#0E1014" CornerRadius="4" Margin="6" Height="150">
                            <Image Source="{Binding PreviewImage}" Stretch="Uniform" StretchDirection="Both" />
                        </Border>
                    </GroupBox>

                    <GroupBox Header="캡처" Margin="0,8,0,0">
                        <StackPanel Margin="6">
                            <TextBlock Text="모니터" />
                            <ComboBox ItemsSource="{Binding Monitors}"
                                      SelectedItem="{Binding SelectedMonitor, Mode=TwoWay}"
                                      DisplayMemberPath="Display" />
                            <TextBlock Text="영역 (X / Y / 너비 / 높이, 픽셀)" Margin="0,8,0,0" />
                            <UniformGrid Columns="4" Margin="0,2,0,0">
                                <TextBox Text="{Binding RegionX, Mode=TwoWay}" Margin="0,0,3,0" />
                                <TextBox Text="{Binding RegionY, Mode=TwoWay}" Margin="0,0,3,0" />
                                <TextBox Text="{Binding RegionWidth, Mode=TwoWay}" Margin="0,0,3,0" />
                                <TextBox Text="{Binding RegionHeight, Mode=TwoWay}" />
                            </UniformGrid>
                            <TextBlock Style="{StaticResource DimLabel}" Margin="0,4,0,0"
                                       Text="너비/높이가 0이면 모니터 전체를 캡처합니다. 모니터·영역은 [설정 저장] 후 다음 세션부터 적용됩니다." />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="인코딩" Margin="0,8,0,0">
                        <StackPanel Margin="6">
                            <TextBlock Text="해상도" />
                            <ComboBox ItemsSource="{Binding ResolutionOptions}"
                                      SelectedItem="{Binding Resolution, Mode=TwoWay}" />
                            <TextBlock Text="프레임레이트 (FPS)" Margin="0,8,0,0" />
                            <ComboBox ItemsSource="{Binding FpsOptions}"
                                      SelectedItem="{Binding Fps, Mode=TwoWay}" />
                            <TextBlock Text="비디오 비트레이트 (kbps, 0=자동)" Margin="0,8,0,0" />
                            <TextBox Text="{Binding VideoBitrateKbps, Mode=TwoWay}" />
                            <TextBlock Text="오디오 비트레이트 (kbps)" Margin="0,8,0,0" />
                            <TextBox Text="{Binding AudioBitrateKbps, Mode=TwoWay}" />
                            <TextBlock Style="{StaticResource DimLabel}" Margin="0,4,0,0"
                                       Text="해상도/FPS가 source면 캡처 모니터를 따릅니다. [설정 저장] 후 다음 세션부터 적용." />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="자원 사용 제한" Margin="0,8,0,0">
                        <StackPanel Margin="6">
                            <ComboBox ItemsSource="{Binding ResourceLimits}"
                                      SelectedItem="{Binding SelectedResourceLimit, Mode=TwoWay}"
                                      ToolTip="스레드/우선순위/프리셋 기반의 근사 상한입니다. 정확한 % 제한이 아닙니다." />
                            <TextBlock Style="{StaticResource DimLabel}" Margin="0,8,0,0"
                                       Text="25/50/75/제한 없음. 정확한 % 제한이 아닌 근사 상한이며, 다음 세션부터 적용됩니다." />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="녹화" Margin="0,8,0,0">
                        <StackPanel Margin="6">
                            <TextBlock Text="{Binding RecordingFileText}" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding RecordingFileText}" />
                            <TextBlock Text="{Binding RecordingUsageText, StringFormat=누적 용량: {0}}"
                                       Margin="0,6,0,0" />
                            <TextBlock Text="{Binding FreeDiskText, StringFormat=남은 디스크: {0}}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="설정" Margin="0,8,0,0">
                        <StackPanel Margin="6">
                            <CheckBox Content="방송 상태 박스 표시 (좌상단 6px)"
                                      IsChecked="{Binding ShowStatusBox, Mode=TwoWay}"
                                      ToolTip="화면 좌상단 모서리의 방송 상태 표시 박스(🟢 라이브 / 🟡 연결 중 / 🔴 오류·중지)를 켜고 끕니다." />
                            <TextBlock Style="{StaticResource DimLabel}" Margin="0,2,0,8"
                                       Text="기본값은 꺼짐이며, 이 항목은 [설정 저장] 없이 즉시 적용됩니다." />

                            <TextBlock Text="제어판 단축키" />
                            <TextBox Text="{Binding HotkeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="자동 시작 방식" Margin="0,8,0,0" />
                            <ComboBox ItemsSource="{Binding AutostartMethods}"
                                      SelectedItem="{Binding AutostartMethod, Mode=TwoWay}"
                                      ToolTip="startup: 시작 프로그램(로그인 후) / scheduler: 작업 스케줄러(로그인 전 가능)" />

                            <TextBlock Text="녹화 폴더" Margin="0,8,0,0" />
                            <TextBox Text="{Binding RecordingFolder, Mode=TwoWay}" />

                            <TextBlock Text="용량 한도 (GB)" Margin="0,8,0,0" />
                            <TextBox Text="{Binding MaxSizeGb, Mode=TwoWay}" />

                            <TextBlock Text="보존 일수" Margin="0,8,0,0" />
                            <TextBox Text="{Binding RetentionDays, Mode=TwoWay}" />

                            <Button Content="설정 저장" Command="{Binding SaveSettingsCommand}"
                                    Margin="0,12,0,0" />

                            <Separator Margin="0,12,0,8" />
                            <TextBlock Text="폰 원격 제어" FontWeight="Bold" />
                            <TextBlock Text="{Binding RemoteStatusText}" TextWrapping="Wrap"
                                       Foreground="{StaticResource DimBrush}" Margin="0,2,0,0" />
                            <TextBlock Text="{Binding RemotePinText}" FontFamily="Consolas" FontSize="18"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 하단 상태바: 현재 실행 버전 + 자동 업데이트 안내(다운로드되어 적용 대기 중일 때만) -->
        <Border Grid.Row="3" Margin="0,10,0,0" Padding="10,5" CornerRadius="4" Background="#15151A">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding VersionText}"
                           Foreground="{StaticResource DimBrush}" FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center" ToolTip="현재 실행 중인 버전" />
                <TextBlock DockPanel.Dock="Right" Text="{Binding UpdateStatusText}"
                           Foreground="#2ECC40" FontWeight="Bold" FontSize="11"
                           VerticalAlignment="Center"
                           Visibility="{Binding UpdateAvailable, Converter={StaticResource B2V}}" />
                <TextBlock />
            </DockPanel>
        </Border>
    </Grid>
</Window>
