<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Windows-only WPF background host. Does NOT build on Linux (WPF/DXGI/WASAPI).
         Build & run verification happens on a local Windows machine — see CLAUDE.md. -->
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>SilentStream.App</RootNamespace>
    <AssemblyName>MediaCaptureHelper</AssemblyName>
    <!-- Win32 FileDescription (작업 관리자 '이름' 열에 노출) → 제품 표시명으로 지정. -->
    <AssemblyTitle>Media Capture Helper</AssemblyTitle>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- Velopack 자동 업데이트: VelopackApp.Run()을 WPF 부팅보다 먼저 실행해야 하므로
         커스텀 진입점(Program.Main)을 사용한다. App.xaml의 자동 생성 Main 대신 이걸 쓴다. -->
    <StartupObject>SilentStream.App.Program</StartupObject>
    <!-- 릴리스 버전(단일 진실 공급원). CI는 태그에서 Version 프로퍼티를 덮어쓰고
         vpk pack 의 packVersion 에도 같은 값을 넘긴다. -->
    <Version>0.1.0</Version>
    <!-- Allows compiling (not running) on Linux when the SDK ships WindowsDesktop
         (official MS SDK; Ubuntu's apt SDK cannot build WPF). -->
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.1" />
    <!-- Microsoft.Win32.TaskScheduler wrapper (plan §5) -->
    <PackageReference Include="TaskScheduler" Version="2.12.2" />
    <!-- Velopack 자동 업데이트 (plan §3.11). Clowd.Squirrel의 유지보수 후속작 —
         GitHub Releases 피드 + 델타 업데이트. 버전은 dotnet add package로 고정한다. -->
    <PackageReference Include="Velopack" Version="1.2.0" />
  </ItemGroup>

  <!-- 임베디드 원격 제어 웹서버(Kestrel) — 확장계획서 §4.4/§10. 프레임워크 종속 배포 시
       대상 PC에 ASP.NET Core 8 런타임이 필요(설치 안내는 docs/USER_GUIDE.md). -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- 모바일 원격 제어 웹 UI + PWA 자산(매니페스트·서비스워커·아이콘)은 어셈블리에 임베드
       (별도 정적 파일 배포 불필요). RemoteControlServer가 임베디드 리소스로 서빙한다. -->
  <ItemGroup>
    <EmbeddedResource Include="Remote\index.html" />
    <EmbeddedResource Include="Remote\manifest.webmanifest" />
    <EmbeddedResource Include="Remote\service-worker.js" />
    <EmbeddedResource Include="Remote\icon.svg" />
    <EmbeddedResource Include="Remote\icon-192.png" />
    <EmbeddedResource Include="Remote\icon-512.png" />
    <EmbeddedResource Include="Remote\icon-maskable.png" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SilentStream.Core\SilentStream.Core.csproj" />
    <ProjectReference Include="..\SilentStream.Media.Windows\SilentStream.Media.Windows.csproj" />
  </ItemGroup>

</Project>
